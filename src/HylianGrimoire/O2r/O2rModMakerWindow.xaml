<Window
    x:Class="HylianGrimoire.O2r.O2rModMakerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Hylian Grimoire - O2R Mod Maker">

    <Grid
        x:Name="RootGrid"
        Padding="20"
        RowSpacing="16"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Name="ToolTitleText"
                Text="O2R Mod Maker"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBlock
                x:Name="ProfileText"
                Grid.Column="1"
                Text="Load a ROM."
                Style="{ThemeResource CaptionTextBlockStyle}"
                VerticalAlignment="Center" />
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="410" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Text="Workspace"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <StackPanel
                        Grid.Row="1"
                        Spacing="8">
                        <Button
                            x:Name="LoadExistingButton"
                            Content="Load existing .o2r"
                            HorizontalAlignment="Stretch"
                            Click="OnLoadExistingMod" />

                        <Button
                            x:Name="CreateButton"
                            Content="Create .o2r"
                            HorizontalAlignment="Stretch"
                            Click="OnCreateMod" />
                    </StackPanel>

                    <Border
                        Grid.Row="2"
                        Padding="12"
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Text="Current mod"
                                Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock
                                x:Name="ExistingModText"
                                Text="No existing mod loaded."
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Name="ModStateText"
                                Text="New mod workspace."
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="3"
                        Padding="12"
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Text="Selection"
                                Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock
                                x:Name="SelectionCountText"
                                Text="0 textures selected."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="4"
                        Padding="12"
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Text="Include"
                                Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <CheckBox
                                x:Name="IncludeTextCheck"
                                Content="Text"
                                Checked="OnIncludeTextChanged"
                                Unchecked="OnIncludeTextChanged" />
                            <CheckBox
                                x:Name="IncludeTexturesCheck"
                                Content="Textures"
                                Checked="OnIncludeTexturesChanged"
                                Unchecked="OnIncludeTexturesChanged" />
                            <TextBlock
                                Text="Text"
                                Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <StackPanel
                                x:Name="TextResourcePanel"
                                Spacing="6" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="Resources"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6">
                            <ToggleButton
                                x:Name="RomViewButton"
                                Content="ROM"
                                Click="OnResourceViewToggled" />
                            <ToggleButton
                                x:Name="ModViewButton"
                                Content=".o2r"
                                Click="OnResourceViewToggled" />
                        </StackPanel>
                    </Grid>

                    <TreeView
                        x:Name="TextureTree"
                        Grid.Row="1"
                        Expanding="OnTextureTreeExpanding"
                        SelectionChanged="OnTextureSelectionChanged">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox
                                        Width="24"
                                        MinWidth="0"
                                        Padding="0"
                                        Margin="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding Content.IsChecked, Mode=TwoWay}"
                                        Click="OnTreeItemCheckClicked" />

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding Content.DisplayText}"
                                        Foreground="{Binding Content.DisplayBrush}"
                                        VerticalAlignment="Center"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <Border
                Grid.Column="2"
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Text="Preview"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <Grid
                        Grid.Row="1"
                        ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="Details"
                            Style="{ThemeResource BodyStrongTextBlockStyle}" />

                        <TextBlock
                            x:Name="DetailsText"
                            Grid.Column="1"
                            Text="Select a texture."
                            TextWrapping="Wrap" />
                    </Grid>

                    <Border
                        x:Name="PreviewViewport"
                        Grid.Row="2"
                        Padding="16"
                        SizeChanged="OnPreviewViewportSizeChanged">
                        <Grid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Image
                                x:Name="PreviewAlphaImage"
                                Stretch="None" />
                            <Image
                                x:Name="PreviewImage"
                                Stretch="None" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <TextBlock
            x:Name="StatusText"
            Grid.Row="2"
            Style="{ThemeResource CaptionTextBlockStyle}"
            TextWrapping="Wrap"
            Text="Open an existing .o2r or create a new one from selected ROM textures." />

        <Grid
            x:Name="ProgressOverlay"
            Grid.RowSpan="3"
            Background="#99000000"
            Visibility="Collapsed"
            Canvas.ZIndex="10">
            <Border
                Width="340"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        x:Name="ProgressTitleText"
                        Text="Creating mod"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        HorizontalAlignment="Center" />

                    <TextBlock
                        x:Name="ProgressPercentText"
                        Grid.Row="1"
                        Text="0%"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        HorizontalAlignment="Center" />

                    <ProgressBar
                        x:Name="ProgressBar"
                        Grid.Row="2"
                        Height="4"
                        Minimum="0"
                        Maximum="100"
                        Value="0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
