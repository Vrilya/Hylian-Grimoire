<Window
    x:Class="HylianGrimoire.Preview.OotPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:preview="using:HylianGrimoire.Preview"
    Title="Hylian Grimoire - Message Preview">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="10,6"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="6">
            <StackPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="18"
                VerticalAlignment="Center">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <Button
                        Width="40"
                        Height="32"
                        Click="OnZoomOut"
                        ToolTipService.ToolTip="Zoom out">
                        <SymbolIcon Symbol="Remove" />
                    </Button>
                    <Button
                        x:Name="ZoomText"
                        Width="58"
                        MinWidth="58"
                        Height="32"
                        Padding="8,0"
                        Content="100%"
                        Click="OnResetZoom"
                        ToolTipService.ToolTip="Reset zoom" />
                    <Button
                        Width="40"
                        Height="32"
                        Click="OnZoomIn"
                        ToolTipService.ToolTip="Zoom in">
                        <SymbolIcon Symbol="Add" />
                    </Button>
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <ToggleButton
                        x:Name="GuideOverlayButton"
                        MinWidth="68"
                        Height="32"
                        Content="Guides"
                        Checked="OnGuideOverlayChanged"
                        Unchecked="OnGuideOverlayChanged"
                        ToolTipService.ToolTip="Show alignment guide lines" />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <CheckBox
                        x:Name="WrapColumnsBox"
                        Width="24"
                        MinWidth="0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Checked="OnColumnLayoutChanged"
                        Unchecked="OnColumnLayoutChanged" />
                    <TextBlock
                        Text="Columns"
                        VerticalAlignment="Center" />
                    <ComboBox
                        x:Name="RowsPerColumnBox"
                        Width="72"
                        IsEnabled="False"
                        SelectionChanged="OnRowsPerColumnChanged">
                        <ComboBoxItem Content="1" />
                        <ComboBoxItem Content="2" />
                        <ComboBoxItem Content="3" />
                        <ComboBoxItem Content="4" />
                        <ComboBoxItem Content="5" />
                        <ComboBoxItem Content="6" />
                        <ComboBoxItem Content="7" />
                        <ComboBoxItem Content="8" />
                    </ComboBox>
                    <TextBlock
                        Text="Rows"
                        VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <ToggleButton
                        x:Name="TopmostButton"
                        Width="44"
                        MinWidth="44"
                        Height="34"
                        Checked="OnTopmostToggled"
                        Unchecked="OnTopmostToggled"
                        ToolTipService.ToolTip="Always on top">
                        <SymbolIcon Symbol="Pin" />
                    </ToggleButton>
                </StackPanel>
            </StackPanel>
        </Border>

        <preview:OotMessagePreviewView
            x:Name="PreviewView"
            Grid.Row="1" />
    </Grid>
</Window>
