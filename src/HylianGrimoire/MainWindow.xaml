<Window
    x:Class="HylianGrimoire.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Hylian Grimoire">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar
            Grid.Row="0"
            DefaultLabelPosition="Right"
            IsOpen="False"
            MinHeight="44">
            <AppBarButton Label="Load" Click="OnLoadFiles">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="OpenFile" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="O" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton Label="Save" Click="OnSaveFiles">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Save" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="S" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton Label="Save As" Click="OnSaveAsFiles">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Save" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton Label="Import Header" Click="OnImportHeader">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Download" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Export Header" Click="OnExportAsHeader">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Share" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarToggleButton
                x:Name="PreviewToggle"
                Label="Preview"
                Click="OnTogglePreview">
                <AppBarToggleButton.Icon>
                    <SymbolIcon Symbol="View" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>
        </CommandBar>

        <Grid Grid.Row="1" Padding="16,4,16,0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" MinWidth="170" />
                <ColumnDefinition Width="*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Text="Message IDs"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBox
                    x:Name="SearchBox"
                    Grid.Row="1"
                    PlaceholderText="Search message text or ID"
                    TextChanged="OnSearchTextChanged" />
                <TextBlock
                    x:Name="SearchStatusText"
                    Grid.Row="2"
                    Style="{ThemeResource CaptionTextBlockStyle}" />
                <ListView
                    x:Name="MessageList"
                    Grid.Row="3"
                    SelectionChanged="OnListSelect"
                    SingleSelectionFollowsFocus="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding Label}"
                                FontFamily="Cascadia Mono"
                                TextTrimming="CharacterEllipsis"
                                RightTapped="OnMessageItemRightTapped" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Grid
                    Grid.Row="4"
                    ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Height="30"
                        Padding="0"
                        Click="OnAddMessageId"
                        ToolTipService.ToolTip="Add message ID">
                        <SymbolIcon Symbol="Add" />
                    </Button>
                    <Button
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Height="30"
                        Padding="0"
                        Click="OnChangeMessageId"
                        ToolTipService.ToolTip="Change message ID">
                        <SymbolIcon Symbol="Edit" />
                    </Button>
                    <Button
                        Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Height="30"
                        Padding="0"
                        Click="OnDeleteMessageId"
                        ToolTipService.ToolTip="Delete message ID">
                        <FontIcon
                            FontFamily="Segoe MDL2 Assets"
                            Glyph="&#xE738;"
                            FontSize="14" />
                    </Button>
                </Grid>
            </Grid>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Text="Editor"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Text="ID"
                        VerticalAlignment="Center" />
                    <TextBox
                        x:Name="IdBox"
                        Grid.Column="1"
                        IsReadOnly="True" />

                    <TextBlock
                        Grid.Column="2"
                        Text="Type"
                        VerticalAlignment="Center" />
                    <ComboBox
                        x:Name="TypeCombo"
                        Grid.Column="3"
                        Width="140"
                        SelectionChanged="OnTypeChange" />

                    <TextBlock
                        Grid.Column="4"
                        Text="Position"
                        VerticalAlignment="Center" />
                    <ComboBox
                        x:Name="PositionCombo"
                        Grid.Column="5"
                        Width="120"
                        SelectionChanged="OnPosChange" />
                </Grid>

                <TextBlock
                    Grid.Row="2"
                    Text="Message text:" />

                <TextBox
                    x:Name="TextEditor"
                    Grid.Row="3"
                    AcceptsReturn="True"
                    FontSize="16"
                    FontFamily="Cascadia Mono"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    TextChanged="OnTextChanged"
                    TextWrapping="NoWrap"
                    VerticalAlignment="Stretch" />

            </Grid>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="16,4"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="StatusText"
                    Text="Load a table (.tbl) and data (.bin) file to begin."
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    VerticalAlignment="Center" />

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="20"
                    VerticalAlignment="Center">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
                        <ToggleSwitch
                            x:Name="WordWrapSwitch"
                            Width="52"
                            MinWidth="0"
                            OffContent=""
                            OnContent=""
                            Toggled="OnWordWrapToggled" />
                        <TextBlock
                            Text="Word wrap"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                        <ComboBox
                            x:Name="EditorFontSizeBox"
                            Width="76"
                            SelectedIndex="2"
                            SelectionChanged="OnEditorFontSizeChanged">
                            <ComboBoxItem Content="12" />
                            <ComboBoxItem Content="14" />
                            <ComboBoxItem Content="16" />
                            <ComboBoxItem Content="18" />
                            <ComboBoxItem Content="20" />
                            <ComboBoxItem Content="22" />
                        </ComboBox>
                        <TextBlock
                            Text="Font size"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <Button
                        Content="Characters"
                        Click="OnOpenGlyphOverrides"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
